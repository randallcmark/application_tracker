{
  "manifest_version": 3,
  "name": "Application Tracker Capture",
  "version": "0.1.0",
  "description": "Capture job pages into a self-hosted Application Tracker.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "action": {
    "default_title": "Capture job",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "application-tracker-capture@example.local",
      "strict_min_version": "109.0"
    }
  }
}
